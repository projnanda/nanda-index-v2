# NANDA Index — production environment
# cp .env.prod.example .env.prod  — then fill in every blank value
# Generate strong secrets: openssl rand -hex 64

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
# Must be at least 32 chars in production
JWT_SECRET=
JWT_EXPIRES_IN=7d

# OAuth — create apps at:
#   Google: console.cloud.google.com  (Authorized redirect: https://api.nandaindex.org/auth/google/callback)
#   GitHub: github.com/settings/developers  (Callback: https://api.nandaindex.org/auth/github/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

OAUTH_CALLBACK_BASE_URL=https://api.nandaindex.org
SMTP_URL=log
EMAIL_FROM=noreply@nandaindex.org
FRONTEND_URL=https://nandaindex.org

# ── Web ───────────────────────────────────────────────────────────────────────
# Baked into the Next.js bundle at build time
NEXT_PUBLIC_NANDA_INDEX_API_URL=https://api.nandaindex.org

# ── Shared ────────────────────────────────────────────────────────────────────
DB_MAX_CONNECTIONS=10
