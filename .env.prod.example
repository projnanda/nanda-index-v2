# NANDA Index — production environment
# cp .env.prod.example .env.prod  — then fill in every blank value
# Generate strong secrets: openssl rand -hex 64

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
# Must be at least 32 chars in production
JWT_SECRET=
JWT_EXPIRES_IN=7d

# OAuth — create apps at:
#   Google: console.cloud.google.com  (Authorized redirect: http://<IP>:3001/auth/google/callback)
#   GitHub: github.com/settings/developers  (Callback: http://<IP>:3001/auth/github/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Base URL the OAuth provider redirects back to (must match registered callback)
OAUTH_CALLBACK_BASE_URL=http://<DROPLET_IP>:3001

# Email — keep "log" to print verification links to stdout (no real email sent)
# Real SMTP: smtp://user:pass@host:587
SMTP_URL=log
EMAIL_FROM=noreply@nandaindex.org

# URL shown in email verification links — set to the web frontend IP
FRONTEND_URL=http://<DROPLET_IP>

# ── Web ───────────────────────────────────────────────────────────────────────
# Baked into the Next.js bundle at build time — must be reachable from the browser
NEXT_PUBLIC_NANDA_INDEX_API_URL=http://<DROPLET_IP>:3001

# ── Shared ────────────────────────────────────────────────────────────────────
DB_MAX_CONNECTIONS=10
