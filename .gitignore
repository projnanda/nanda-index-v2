# Environment
.env
.env.local

# Dependencies
server/node_modules/
web/node_modules/

# Build output
server/dist/
web/.next/
web/tsconfig.tsbuildinfo

# Logs
*.log

# OS
.DS_Store

# Static files served directly by Caddy on the droplet (e.g. paper.pdf) —
# uploaded straight to the server, not tracked in git.
/static/*
!/static/.gitkeep
