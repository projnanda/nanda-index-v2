# NANDA Index — environment variables
# Copy to .env and fill in values before running docker compose up

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=nanda-local

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ── OAuth (optional — create apps at console.cloud.google.com / github.com/settings/developers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:3001

# ── Email (log = print verification link to console; no real email sent)
SMTP_URL=log
EMAIL_FROM=noreply@nanda.local

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Public API URL used by the Next.js frontend at build time
NEXT_PUBLIC_NANDA_INDEX_API_URL=http://localhost:3001

# ── Misc ──────────────────────────────────────────────────────────────────────
DB_MAX_CONNECTIONS=10

# ── Signing (optional — only for signed IndexRecord responses)
SIGNING_KEY_ID=
SIGNING_PRIVATE_KEY=
